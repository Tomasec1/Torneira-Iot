        "z": "ffaa1f7d0c3ffdfc",
        "name": "Inserir consumo manual",
        "query": "WITH entrada AS (\n  SELECT\n    CAST($id_bebida AS int) AS id_bebida,\n    CAST($id_vinculo AS int) AS id_vinculo,\n    COALESCE(CAST($quantidade_ml AS numeric), 0) AS quantidade_ml\n),\ndados_banco AS (\n  SELECT\n    e.id_bebida,\n    e.id_vinculo,\n    e.quantidade_ml,\n    v.id_copo,\n    COALESCE(v.bonus_total, 0)::numeric AS bonus_antes,\n    t.bebidas AS nome_bebida,\n    COALESCE(t.preco, 0)::numeric AS preco_litro\n  FROM entrada e\n  JOIN vinculo_copo_cliente v ON v.id = e.id_vinculo\n  JOIN torneira t ON t.id = e.id_bebida\n),\ncalculo AS (\n  SELECT\n    id_bebida,\n    id_vinculo,\n    id_copo,\n    quantidade_ml,\n    nome_bebida,\n    preco_litro,\n    bonus_antes,\n    ROUND((preco_litro * quantidade_ml / 1000.0), 2) AS valor_real\n  FROM dados_banco\n),\ncalculo_final AS (\n  SELECT\n    id_bebida,\n    id_vinculo,\n    id_copo,\n    quantidade_ml,\n    nome_bebida,\n    preco_litro,\n    bonus_antes,\n    valor_real,\n    LEAST(valor_real, bonus_antes) AS desconto_usado,\n    GREATEST(valor_real - LEAST(valor_real, bonus_antes), 0) AS valor_pos_desconto,\n    GREATEST(bonus_antes - LEAST(valor_real, bonus_antes), 0) AS bonus_restante\n  FROM calculo\n),\natualiza_bonus AS (\n  UPDATE vinculo_copo_cliente\n  SET bonus_total = ROUND((SELECT bonus_restante FROM calculo_final), 2)\n  WHERE id = (SELECT id_vinculo FROM calculo_final)\n  RETURNING id, bonus_total\n),\ninsere_consumo AS (\n  INSERT INTO consumo_bebidas (\n    quantidade_ml,\n    valor_real,\n    desconto,\n    vinculo_copo_cliente,\n    id_bebida,\n    id_copo\n  )\n  SELECT\n    ROUND(quantidade_ml)::int,\n    ROUND(valor_real, 2),\n    ROUND(desconto_usado, 2),\n    id_vinculo,\n    id_bebida,\n    id_copo\n  FROM calculo_final\n  RETURNING\n    id,\n    created_at,\n    quantidade_ml,\n    valor_real,\n    desconto,\n    vinculo_copo_cliente,\n    id_bebida,\n    id_copo\n)\nSELECT\n  true AS salvo,\n  i.id AS id_consumo,\n  i.created_at,\n  c.nome_bebida,\n  c.preco_litro,\n  c.bonus_antes,\n  i.quantidade_ml,\n  i.valor_real,\n  i.desconto AS desconto_usado,\n  c.valor_pos_desconto,\n  COALESCE(a.bonus_total, c.bonus_restante) AS bonus_restante,\n  i.vinculo_copo_cliente,\n  i.id_bebida,\n  i.id_copo\nFROM insere_consumo i\nJOIN calculo_final c ON c.id_vinculo = i.vinculo_copo_cliente\nLEFT JOIN atualiza_bonus a ON a.id = i.vinculo_copo_cliente;",
        "postgreSQLConfig": "1251550e75985b59",
        "split": false,
        "rowsPerMsg": 1,
        "outputs": 1,
        "x": 660,
        "y": 740,
        "wires": [
            [
                "12f8f3ffc031eebc",
                "c720085a686ca5f9"
            ]
        ]
    },
    {
        "id": "12f8f3ffc031eebc",
        "type": "function",
        "z": "ffaa1f7d0c3ffdfc",
        "name": "Mensagem resultado",
        "func": "let r = Array.isArray(msg.payload) ? msg.payload[0] : msg.payload;\n\nif (!r) {\n    msg.payload = \"Erro: consumo não inserido. Verifique se o ID da bebida e o ID do vínculo existem.\";\n    return msg;\n}\n\nmsg.payload =\n    \"Consumo inserido com sucesso! \" +\n    \"ID: \" + r.id_consumo +\n    \" | Bebida: \" + r.nome_bebida +\n    \" | Volume: \" + r.quantidade_ml + \" mL\" +\n    \" | Preço/L: R$ \" + Number(r.preco_litro).toFixed(2) +\n    \" | Bônus antes: R$ \" + Number(r.bonus_antes).toFixed(2) +\n    \" | Valor real: R$ \" + Number(r.valor_real).toFixed(2) +\n    \" | Desconto: R$ \" + Number(r.desconto_usado).toFixed(2) +\n    \" | Valor final: R$ \" + Number(r.valor_pos_desconto).toFixed(2) +\n    \" | Bônus restante: R$ \" + Number(r.bonus_restante).toFixed(2);\n\nreturn msg;",
        "outputs": 1,
