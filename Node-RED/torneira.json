    {
        "id": "174012406af2a48f",
        "type": "postgresql",
        "z": "ffaa1f7d0c3ffdfc",
        "name": "Salvar consumo e atualizar bônus",
        "query": "WITH dados AS (\n  SELECT\n    $id_torneira::int AS id_bebida,\n    $id_vinculo::int AS id_vinculo,\n    $id_copo::int AS id_copo,\n    COALESCE($quantidade_ml::numeric, 0) AS quantidade_ml,\n    COALESCE($valor_real::numeric, 0) AS valor_real,\n    COALESCE($desconto_usado::numeric, 0) AS desconto_usado,\n    COALESCE($bonus_restante::numeric, 0) AS bonus_restante\n),\natualiza_bonus AS (\n  UPDATE vinculo_copo_cliente\n  SET bonus_total = GREATEST(ROUND((SELECT bonus_restante FROM dados), 2), 0)\n  WHERE id = (SELECT id_vinculo FROM dados)\n  RETURNING id, bonus_total\n),\ninsere_consumo AS (\n  INSERT INTO consumo_bebidas (\n    quantidade_ml,\n    valor_real,\n    desconto,\n    vinculo_copo_cliente,\n    id_bebida,\n    id_copo\n  )\n  SELECT\n    ROUND(quantidade_ml)::int,\n    ROUND(valor_real, 2),\n    ROUND(desconto_usado, 2),\n    id_vinculo,\n    id_bebida,\n    id_copo\n  FROM dados\n  RETURNING\n    id,\n    created_at,\n    quantidade_ml,\n    valor_real,\n    desconto,\n    vinculo_copo_cliente,\n    id_bebida,\n    id_copo\n)\nSELECT\n  true AS salvo,\n  i.id AS id_consumo,\n  i.quantidade_ml,\n  i.valor_real,\n  i.desconto AS desconto_usado,\n  GREATEST(i.valor_real - i.desconto, 0) AS valor_pos_desconto,\n  COALESCE(a.bonus_total, (SELECT bonus_restante FROM dados)) AS bonus_restante,\n  i.vinculo_copo_cliente,\n  i.id_bebida,\n  i.id_copo\nFROM insere_consumo i\nLEFT JOIN atualiza_bonus a ON a.id = i.vinculo_copo_cliente;",
        "postgreSQLConfig": "1251550e75985b59",
        "split": false,
        "rowsPerMsg": 1,
        "outputs": 1,
        "x": 630,
        "y": 430,
        "wires": [
            [
                "f25d256c72d9f3e2",
                "e8d2c7cc18597a39"
            ]
        ]
    },
