    {
        "id": "6eb4d53268d7b8dc",
        "type": "function",
        "z": "ffaa1f7d0c3ffdfc",
        "name": "Preparar dados com padrão",
        "func": "const p = msg.payload || {};\n\n// ===============================\n// VALORES PADRÃO DO FORMULÁRIO\n// ===============================\nconst padrao = {\n    id_bebida: 1,\n    id_vinculo: 135,\n    quantidade_ml: 500\n};\n\n// Se algum campo vier vazio, usa o valor padrão\nfor (let campo in padrao) {\n    if (\n        p[campo] === undefined ||\n        p[campo] === null ||\n        p[campo] === \"\" ||\n        isNaN(Number(p[campo]))\n    ) {\n        p[campo] = padrao[campo];\n    }\n}\n\nmsg.queryParameters = {\n    id_bebida: Number(p.id_bebida),\n    id_vinculo: Number(p.id_vinculo),\n    quantidade_ml: Number(p.quantidade_ml)\n};\n\nmsg.payload = msg.queryParameters;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 390,
        "y": 740,
        "wires": [
