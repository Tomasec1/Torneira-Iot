    {
        "id": "bdf8c69791f393c0",
        "type": "postgresql",
        "z": "ffaa1f7d0c3ffdfc",
        "name": "Buscar vínculo do copo",
        "query": "SELECT\n  v.id AS id_vinculo,\n  v.id_cliente,\n  v.id_copo,\n  COALESCE(v.bonus_total, 0) AS bonus_total\nFROM vinculo_copo_cliente v\nJOIN copos c ON c.id = v.id_copo\nWHERE regexp_replace(upper(c.rfid), '[^0-9A-F]', '', 'g')\n    = regexp_replace(upper($rfid::text), '[^0-9A-F]', '', 'g')\n  AND v.ativo = true\n  AND c.status = 'em_uso'\nORDER BY v.data_vinculo DESC NULLS LAST, v.id DESC\nLIMIT 1;",
        "postgreSQLConfig": "1251550e75985b59",
        "split": false,
        "rowsPerMsg": 1,
