  {
      "id": "61c1bb752b0c94c7",
      "type": "function",
      "z": "05612c0fa82cfdea",
      "name": "Calculo bônus",
      "func": "// msg.payload = array de bets dessa partida\n// msg.gols_mandante, msg.gols_visitante, msg.id_mandante, msg.id_visitante já vêm no msg\n\nconst golsMandante = msg.gols_mandante;\nconst golsVisitante = msg.gols_visitante;\nconst idMandante = msg.id_mandante;\nconst idVisitante = msg.id_visitante;\n\n// Descobre o vencedor: id do time, ou null se empate\nlet idTimeVencedor = null;\nif (golsMandante > golsVisitante) {\n    idTimeVencedor = idMandante;\n} else if (golsVisitante > golsMandante) {\n    idTimeVencedor = idVisitante;\n}\n// se golsMandante === golsVisitante, continua null (empate)\n\nconst bets = msg.payload;\n\n// Normaliza null/undefined pra comparar igual\nconst apostaBateComVencedor = (bet) => {\n    const apostaEmpate = (bet.id_time_apostado === null || bet.id_time_apostado === undefined);\n    const foiEmpate = (idTimeVencedor === null);\n    if (apostaEmpate) return foiEmpate;\n    return bet.id_time_apostado === idTimeVencedor;\n};\n\n// Separa vencedores e perdedores\nconst vencedores = bets.filter(apostaBateComVencedor);\nconst perdedores = bets.filter(b => !apostaBateComVencedor(b));\n\nconst poolVencedor = vencedores.reduce((soma, b) => soma + Number(b.valor_apostado), 0);\nconst poolPerdedor = perdedores.reduce((soma, b) => soma + Number(b.valor_apostado), 0);\n\nconst betsAtualizadas = bets.map(bet => {\n    const acertou = apostaBateComVencedor(bet);\n    let bonusDinheiro = 0;\n\n    if (acertou) {\n        const proporcao = poolVencedor > 0 ? (Number(bet.valor_apostado) / poolVencedor) : 0;\n        const ganhoDoPoolPerdedor = proporcao * poolPerdedor;\n        bonusDinheiro = Number(bet.valor_apostado) + ganhoDoPoolPerdedor;\n    }\n\n    return {\n        ...bet,\n        acertou,\n        bonus_dinheiro: Number(bonusDinheiro.toFixed(2))\n    };\n});\n\nmsg.payload = betsAtualizadas;\nmsg.id_time_vencedor = idTimeVencedor; \nreturn msg;",
      "outputs": 1,
      "timeout": 0,
      "noerr": 0,
      "initialize": "",
      "finalize": "",
      "libs": [],
      "x": 1680,
      "y": 240,
      "wires": [
          [
              "7a1444d92521acb4",
              "44008161fecf24de",
              "f7f6c51a732cc1c5"
          ]
      ]
  },
  {
      "id": "566fdfb76f4f7f26",
      "type": "function",
      "z": "05612c0fa82cfdea",
      "name": "Montar query",
      "func": "// Salva os gols pra usar no cálculo do resultado 1X2 depois\nmsg.gols_mandante  = msg.payload.gols_mandante;\nmsg.gols_visitante = msg.payload.gols_visitante;\nmsg.id_mandante = msg.payload.mandante;\nmsg.id_visitante = msg.payload.visitante;\n\nmsg.queryParameters = {\n    id_partida: msg.payload.id\n};\n\nreturn msg;",
