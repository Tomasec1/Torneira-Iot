  {
      "id": "44008161fecf24de",
      "type": "function",
      "z": "05612c0fa82cfdea",
      "name": "Calcula bônus que cada cliente teve por partida",
      "func": "const bets = msg.payload;\n\n// Agrupa por id_cliente, somando o bonus_dinheiro de cada um\nconst totaisPorCliente = {};\n\nbets.forEach(bet => {\n    const idCliente = bet.id_cliente;\n    const bonus = Number(bet.bonus_dinheiro);\n\n    if (!totaisPorCliente[idCliente]) {\n        totaisPorCliente[idCliente] = 0;\n    }\n    totaisPorCliente[idCliente] += bonus;\n});\n\n// Transforma o objeto agrupado num array de { id_cliente, bonus_total }\nconst bonusPorCliente = Object.keys(totaisPorCliente).map(idCliente => ({\n    id_cliente: Number(idCliente),\n    bonus_total: Number(totaisPorCliente[idCliente].toFixed(2))\n}));\n\nmsg.payload = bonusPorCliente;\nreturn msg;",
      "outputs": 1,
      "timeout": 0,
      "noerr": 0,
      "initialize": "",
      "finalize": "",
