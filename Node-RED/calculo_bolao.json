  {
      "id": "b62af96de086f477",
      "type": "function",
      "z": "05612c0fa82cfdea",
      "name": "Calcula bônus que cada cliente teve juntando todas as partidas",
      "func": "const arrayDeArrays = msg.payload;\n\n// achata: transforma array de arrays num array só\nconst todosOsBonus = arrayDeArrays.flat();\n\n// agrupa por id_cliente, somando bonus_total entre todas as partidas\nconst totaisPorCliente = {};\n\ntodosOsBonus.forEach(item => {\n    const idCliente = item.id_cliente;\n    const bonus = Number(item.bonus_total);\n\n    if (!totaisPorCliente[idCliente]) {\n        totaisPorCliente[idCliente] = 0;\n    }\n    totaisPorCliente[idCliente] += bonus;\n});\n\nconst bonusGeral = Object.keys(totaisPorCliente).map(idCliente => ({\n    id_cliente: Number(idCliente),\n    bonus_total: Number(totaisPorCliente[idCliente].toFixed(2))\n}));\n\nmsg.payload = bonusGeral;\nreturn msg;",
