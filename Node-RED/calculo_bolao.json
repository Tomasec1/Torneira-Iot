      "id": "f7927c6bc7cf7edc",
      "type": "postgresql",
      "z": "05612c0fa82cfdea",
      "name": "Buscar apostas sobre as partidas finalizadas",
      "query": "SELECT * FROM bets\nWHERE id_partida = $id_partida;",
      "postgreSQLConfig": "1251550e75985b59",
      "split": false,
      "rowsPerMsg": 1,
      "outputs": 1,
      "x": 1350,
